---
import Button from "../ui/Button.astro";

interface Props {
  currentPage?: string;
}

const { currentPage = "home" } = Astro.props;

const navLinks = [
  { label: "HOME", href: "/#", id: "home" },
  { label: "PRICING", href: "/#pricing", id: "pricing" },
  { label: "GET TO KNOW US", href: "/about", id: "about" },
];
---

<!-- Mobile Top Bar (logo only) -->
<div class="lg:hidden flex items-center px-4 py-3 bg-brand-dark/95 backdrop-blur-md fixed top-0 left-0 right-0 z-50">
  <a href="/" class="flex flex-col">
    <div class="font-heading text-2xl font-bold leading-tight">
      <span class="text-white">merge</span><span class="text-brand-primary">wello</span>
    </div>
    <span class="text-brand-light text-[10px] font-medium font-body tracking-[0.15em]">TECHNOLOGIES</span>
  </a>
</div>

<div class="lg:hidden h-14"></div>

<!-- Desktop Navbar -->
<nav class="hidden lg:flex items-center justify-between px-10 xl:px-20 py-6 bg-brand-dark fixed top-0 left-0 right-0 z-50">
  <!-- Logo -->
  <a href="/" class="flex flex-col shrink-0">
    <div class="font-heading text-3xl xl:text-4xl font-bold leading-tight">
      <span class="text-white">merge</span><span class="text-brand-primary">wello</span>
    </div>
    <span class="text-brand-light text-xs font-medium font-body tracking-[0.15em]">TECHNOLOGIES</span>
  </a>

  <!-- Nav Links -->
  <div class="flex items-center gap-10 xl:gap-12">
    {navLinks.map((link) => (
      <a
        href={link.href}
        data-nav-link={link.id}
        class:list={[
          "relative text-base font-medium font-body uppercase tracking-wide transition-colors duration-200 hover:text-brand-primary",
          currentPage === link.id ? "text-brand-primary" : "text-white",
        ]}
      >
        {link.label}
        <span
          data-underline
          class:list={[
            "absolute -bottom-2 left-0 w-full h-0.75 bg-brand-primary rounded-full transition-opacity duration-200",
            currentPage === link.id ? "" : "hidden",
          ]}
        />
      </a>
    ))}
  </div>

  <!-- CTA -->
  <Button text="GET A QUOTE" href="/#contact" size="md" />
</nav>

<!-- Mobile Bottom Nav -->
<nav class="lg:hidden fixed bottom-0 left-0 right-0 z-50 bg-brand-dark/95 backdrop-blur-md border-t border-white/10">
  <div class="flex items-center justify-around px-2 py-2">
    {navLinks.map((link) => (
      <a
        href={link.href}
        data-nav-link-mobile={link.id}
        class:list={[
          "flex flex-col items-center gap-1 px-3 py-2 rounded-xl text-xs font-semibold font-body uppercase transition-colors duration-200",
          currentPage === link.id ? "text-brand-primary" : "text-white/70 hover:text-white",
        ]}
      >
        {link.id === "home" && (
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1" />
          </svg>
        )}
        {link.id === "pricing" && (
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5a1.99 1.99 0 011.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z" />
          </svg>
        )}
        {link.id === "about" && (
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        )}
        <span>{link.id === "about" ? "ABOUT" : link.label}</span>
      </a>
    ))}

    <!-- Mobile CTA -->
    <a
      href="/#contact"
      data-nav-link-mobile="contact"
      class="flex flex-col items-center gap-1 px-3 py-2 text-brand-primary"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
      </svg>
      <span class="text-xs font-medium font-body">QUOTE</span>
    </a>
  </div>
</nav>

<!-- Spacer for fixed desktop nav -->
<div class="hidden lg:block h-20"></div>

<script>
  const sections = ["hero", "pricing", "contact"];
  const navLinks = document.querySelectorAll("[data-nav-link]");
  const mobileLinks = document.querySelectorAll("[data-nav-link-mobile]");

  function updateActiveLink() {
    const scrollY = window.scrollY + 200;

    let current = "";

    for (const id of sections) {
      const section = document.getElementById(id);
      if (section && section.offsetTop <= scrollY) {
        current = id;
      }
    }

    const linkMap: Record<string, string> = {
      hero: "home",
      pricing: "pricing",
      contact: "contact",
    };

    const activeId = linkMap[current] || "";

    // Update page title
    const titleMap: Record<string, string> = {
      pricing: "Pricing",
      contact: "Contact",
    };
    const pageTitle = titleMap[activeId] || "";
    document.title = pageTitle 
    ? `${pageTitle} - Mergewello Technologies` 
    : "Mergewello Technologies";
    document.title = `${pageTitle} - Mergewello Technologies`;

    // Desktop nav — no highlight on contact
    const highlightId = activeId === "contact" ? "" : activeId;

    navLinks.forEach((link) => {
      const linkId = link.getAttribute("data-nav-link");
      const underline = link.querySelector("[data-underline]");

      if (linkId === highlightId) {
        link.classList.add("text-brand-primary");
        link.classList.remove("text-white");
        underline?.classList.remove("hidden");
      } else {
        link.classList.remove("text-brand-primary");
        link.classList.add("text-white");
        underline?.classList.add("hidden");
      }
    });

    // Mobile nav — highlight active section
    mobileLinks.forEach((link) => {
      const linkId = link.getAttribute("data-nav-link-mobile");

      if (linkId === activeId) {
        link.classList.add("text-brand-primary");
        link.classList.remove("text-white/70");
      } else if (linkId === "contact") {
        // Quote button stays brand-primary always
        link.classList.add("text-brand-primary");
      } else {
        link.classList.remove("text-brand-primary");
        link.classList.add("text-white/70");
      }
    });
  }

  if (document.getElementById("hero")) {
    window.addEventListener("scroll", updateActiveLink);
    updateActiveLink();
  }
</script>