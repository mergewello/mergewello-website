---
const socials = [
  { name: "Facebook", href: "https://www.facebook.com/people/Mergewello-Technologies/61578251879282/", icon: "/icons/facebook.svg" },
  { name: "LinkedIn", href: "https://www.linkedin.com/company/mergewellotech/", icon: "/icons/linkedin.svg" },
  { name: "TikTok", href: "#", icon: "/icons/tiktok.svg" },
  { name: "Instagram", href: "#", icon: "/icons/instagram.svg" },
];
---

<aside class="hidden lg:flex fixed left-0 top-1/2 -translate-y-1/2 z-40 flex-col items-center">
  <!-- Teal bar behind -->
  <div class="absolute inset-0 bg-brand-primary rounded-tr-xl rounded-br-xl -z-10"></div>

  <!-- Social icons -->
  <div class="flex flex-col">
    {socials.map((social, index) => (
      <a
        href={social.href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={social.name}
        class:list={[
          "w-14 h-14 flex items-center justify-center bg-brand-accent transition-transform duration-200 hover:scale-110",
          index === 0 && "rounded-tr-xl",
          index === socials.length - 1 && "rounded-br-xl",
        ]}
      >
        <img src={social.icon} alt={social.name} class="w-6 h-6" />
      </a>
    ))}
  </div>
</aside>