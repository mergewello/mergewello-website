---
import Button from "../ui/Button.astro";

const packages = [
  { value: "", label: "Choose Package" },
  { value: "starter", label: "Starter – ₱3,000" },
  { value: "growth", label: "Growth – ₱5,000 + ₱2,000/mo" },
  { value: "full-launch", label: "Full Launch – ₱12,000" },
];

const deadlines = [
  { value: "", label: "Choose Deadline" },
  { value: "3-4-days", label: "3 – 4 days" },
  { value: "5-7-days", label: "5 – 7 days" },
  { value: "7-plus-days", label: "More than 7 days" },
];

const contactInfo = [
  {
    label: "Phone Number",
    value: "+639453964266",
    href: "tel:+639453964266",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />`,
  },
  {
    label: "Email",
    value: "contact@mergewello.com",
    href: "mailto:contact@mergewello.com",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />`,
  },
  {
    label: "Address",
    value: ["Iloilo City, Philippines", "Roxas City, Philippines"],
    href: null,
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />`,
  },
];
---

<section id="contact" class="bg-brand-dark py-16 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-16">

    <!-- Header -->
    <div class="text-center mb-10 lg:mb-14">
      <h2 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-semibold text-brand-primary mb-3">
        Let's Build Something Amazing
      </h2>
      <p class="font-body text-base sm:text-lg font-medium text-white">
        Fill out the form and let's turn your ideas into reality
      </p>
    </div>

    <div class="flex flex-col lg:flex-row gap-12 lg:gap-16">

      <!-- Form -->
      <form
        id="contact-form"
        action="https://formspree.io/f/myklgejy"
        method="POST"
        class="flex-1 space-y-5"
        novalidate
      >
        <input
        type="text"
        name="_gotcha"
        style="display:none !important"
        tabindex="-1"
        autocomplete="off"
        />
        <!-- Row 1: Name + Email -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div class="relative">
            <input
              type="text"
              name="name"
              required
              placeholder="Full Name"
              class="w-full bg-brand-dark border border-white/30 rounded-2xl px-5 py-4 font-heading text-base text-white placeholder-stone-400 outline-none transition-colors duration-200 focus:border-brand-primary focus:ring-1 focus:ring-brand-primary"
            />
            <span class="field-error hidden font-body text-xs text-red-400 mt-1 ml-2 absolute -bottom-5 left-0">Please enter your name</span>
          </div>
          <div class="relative">
            <input
              type="email"
              name="email"
              required
              placeholder="Email Address"
              class="w-full bg-brand-dark border border-white/30 rounded-2xl px-5 py-4 font-heading text-base text-white placeholder-stone-400 outline-none transition-colors duration-200 focus:border-brand-primary focus:ring-1 focus:ring-brand-primary"
            />
            <span class="field-error hidden font-body text-xs text-red-400 mt-1 ml-2 absolute -bottom-5 left-0">Please enter a valid email</span>
          </div>
        </div>

        <!-- Row 2: Phone + Subject -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 pt-2">
          <div class="relative">
            <input
              type="tel"
              name="phone"
              required
              placeholder="Phone Number"
              class="w-full bg-brand-dark border border-white/30 rounded-2xl px-5 py-4 font-heading text-base text-white placeholder-stone-400 outline-none transition-colors duration-200 focus:border-brand-primary focus:ring-1 focus:ring-brand-primary"
            />
            <span class="field-error hidden font-body text-xs text-red-400 mt-1 ml-2 absolute -bottom-5 left-0">Please enter your phone number</span>
          </div>
          <div class="relative">
            <input
              type="text"
              name="subject"
              required
              placeholder="Subject"
              class="w-full bg-brand-dark border border-white/30 rounded-2xl px-5 py-4 font-heading text-base text-white placeholder-stone-400 outline-none transition-colors duration-200 focus:border-brand-primary focus:ring-1 focus:ring-brand-primary"
            />
            <span class="field-error hidden font-body text-xs text-red-400 mt-1 ml-2 absolute -bottom-5 left-0">Please enter a subject</span>
          </div>
        </div>

        <!-- Row 3: Package + Deadline -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 pt-2">
          <div class="relative">
            <select
              name="package"
              required
              class="w-full bg-brand-dark border border-white/30 rounded-2xl px-5 py-4 font-heading text-base text-stone-400 outline-none transition-colors duration-200 focus:border-brand-primary focus:ring-1 focus:ring-brand-primary appearance-none cursor-pointer"
            >
              {packages.map((pkg) => (
                <option value={pkg.value} disabled={pkg.value === ""} selected={pkg.value === ""}>
                  {pkg.label}
                </option>
              ))}
            </select>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-stone-400 absolute right-5 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
            <span class="field-error hidden font-body text-xs text-red-400 mt-1 ml-2 absolute -bottom-5 left-0">Please select a package</span>
          </div>
          <div class="relative">
            <select
              name="deadline"
              required
              class="w-full bg-brand-dark border border-white/30 rounded-2xl px-5 py-4 font-heading text-base text-stone-400 outline-none transition-colors duration-200 focus:border-brand-primary focus:ring-1 focus:ring-brand-primary appearance-none cursor-pointer"
            >
              {deadlines.map((dl) => (
                <option value={dl.value} disabled={dl.value === ""} selected={dl.value === ""}>
                  {dl.label}
                </option>
              ))}
            </select>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-stone-400 absolute right-5 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
            <span class="field-error hidden font-body text-xs text-red-400 mt-1 ml-2 absolute -bottom-5 left-0">Please select a deadline</span>
          </div>
        </div>

        <!-- Row 4: Message -->
        <div class="relative pt-2">
          <textarea
            name="message"
            required
            placeholder="Message"
            rows="6"
            class="w-full bg-brand-dark border border-white/30 rounded-2xl px-5 py-4 font-heading text-base text-white placeholder-stone-400 outline-none transition-colors duration-200 focus:border-brand-primary focus:ring-1 focus:ring-brand-primary resize-none"
          ></textarea>
          <span class="field-error hidden font-body text-xs text-red-400 mt-1 ml-2 absolute -bottom-4 left-0">Please enter your message</span>
        </div>

        <!-- Submit -->
        <div class="pt-4">
          <button
            type="submit"
            class="inline-block bg-linear-to-br from-brand-primary to-emerald-600 text-white font-medium font-body text-base uppercase tracking-wide rounded-[20px] px-8 py-4 transition-all duration-200 hover:scale-105 hover:shadow-lg hover:shadow-brand-primary/20 cursor-pointer"
          >
            SEND MESSAGE
          </button>
        </div>

        <!-- Success Message -->
        <div id="form-success" class="hidden bg-brand-primary/10 border border-brand-primary/30 rounded-2xl p-5 text-center">
          <p class="font-heading text-lg font-semibold text-brand-primary">Message sent!</p>
          <p class="font-body text-sm text-white/80 mt-1">We'll get back to you within 24 hours.</p>
        </div>
      </form>

      <!-- Contact Info -->
      <div class="lg:w-85 xl:w-100 space-y-10 lg:pt-4">
        {contactInfo.map((info) => (
          <div class="flex items-start gap-5">
            <div class="w-12 h-12 shrink-0 bg-linear-to-bl from-brand-primary to-emerald-800 rounded-full flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <Fragment set:html={info.icon} />
              </svg>
            </div>
            <div>
              <p class="font-heading text-sm lg:text-base font-normal text-stone-400 mb-1">{info.label}</p>
              {Array.isArray(info.value) ? (
                info.value.map((v) => (
                  <p class="font-heading text-lg lg:text-xl font-normal text-white">{v}</p>
                ))
              ) : info.href ? (
                <a href={info.href} class="font-heading text-lg lg:text-xl font-normal text-white hover:text-brand-primary transition-colors duration-200">
                  {info.value}
                </a>
              ) : (
                <p class="font-heading text-lg lg:text-xl font-normal text-white">{info.value}</p>
              )}
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

<!-- Form Validation & Submission -->
<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const success = document.getElementById("form-success") as HTMLElement;
  const loadTime = Date.now();

  // Change select color when an option is chosen
  form.querySelectorAll("select").forEach((select) => {
    select.addEventListener("change", () => {
      if (select.value) {
        select.classList.remove("text-stone-400");
        select.classList.add("text-white");
      }
    });
  });

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    // Bot speed check — humans take at least 5 seconds
    if (Date.now() - loadTime < 5000) {
    // Silently pretend it worked so bots don't retry
    Array.from(form.children).forEach((child) => {
        if (child.id !== "form-success") {
        (child as HTMLElement).classList.add("hidden");
        }
    });
    success.classList.remove("hidden");
    return;
    }

    // Reset errors
    form.querySelectorAll(".field-error").forEach((el) => el.classList.add("hidden"));
    form.querySelectorAll("input, select, textarea").forEach((el) => {
      el.classList.remove("border-red-400");
    });

    let hasError = false;

    // Validate each required field
    form.querySelectorAll("[required]").forEach((field) => {
      const el = field as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement;
      const wrapper = el.closest(".relative");
      const errorEl = wrapper?.querySelector(".field-error");

      let invalid = false;

      if (el.type === "email") {
        invalid = !el.value.trim() || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(el.value.trim());
      } else if (el.tagName === "SELECT") {
        invalid = !el.value;
      } else {
        invalid = !el.value.trim();
      }

      if (invalid) {
        hasError = true;
        el.classList.add("border-red-400");
        errorEl?.classList.remove("hidden");
      }
    });

    if (hasError) return;

    // Submit
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = submitBtn.textContent;
    submitBtn.textContent = "SENDING...";
    submitBtn.disabled = true;

    try {
      const formData = new FormData(form);
      const response = await fetch(form.action, {
        method: "POST",
        body: formData,
        headers: { Accept: "application/json" },
      });
      
      if (response.ok) {
        form.reset();
        // Hide all form children except success message
        Array.from(form.children).forEach((child) => {
            if (child.id !== "form-success") {
            (child as HTMLElement).classList.add("hidden");
            }
        });
        success.classList.remove("hidden");

        // Reset select colors
        form.querySelectorAll("select").forEach((select) => {
          select.classList.add("text-stone-400");
          select.classList.remove("text-white");
        });
      } else {
        submitBtn.textContent = "FAILED — TRY AGAIN";
        setTimeout(() => {
          submitBtn.textContent = originalText;
          submitBtn.disabled = false;
        }, 3000);
      }
    } catch {
      submitBtn.textContent = "FAILED — TRY AGAIN";
      setTimeout(() => {
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
      }, 3000);
    }
  });
</script>