---
import "../styles/global.css";
interface Props {
  title: string;
  description?: string;
  currentPage?: string;
}

const {
  title,
  description = "We help local businesses in Aklan, Antique, Capiz, and Iloilo get online.",
  currentPage = "",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Mergewello Technologies</title>
  </head>
  <body class="min-h-screen antialiased">
    <slot />
  </body>
</html>