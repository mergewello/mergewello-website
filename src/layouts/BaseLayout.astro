---
import "../styles/global.css";
interface Props {
  title: string;
  description?: string;
  currentPage?: string;
}

const {
  title,
  description = "We help local businesses in Aklan, Antique, Capiz, and Iloilo get online.",
  currentPage = "",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@400;600;700&family=DM+Sans:wght@300;400;500;600;800&display=swap" rel="stylesheet" />
    <title>{title} | Mergewello Technologies</title>
  </head>
  <body class="min-h-screen antialiased">
    <slot />
  </body>
</html>