---
import "../styles/global.css";
import StructuredData from "../components/ui/StructuredData.astro";
import Analytics from "../components/ui/Analytics.astro";

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
}

const {
  title = "Web Development Agency in Panay",
  description = "Mergewello Technologies builds fast, modern websites for small businesses in Panay, Philippines. Affordable web design and development for Iloilo, Aklan, Antique, and Capiz.",
  noindex = false,
} = Astro.props;

const siteUrl = "https://mergewello.com";
const currentPath = Astro.url.pathname;
const canonicalUrl = `${siteUrl}${currentPath}`;
const pageTitle = `${title} - Mergewello Technologies`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="keywords" content="web design iloilo, website developer iloilo, web developer panay, affordable website philippines, business website aklan, website design capiz, web design roxas city, website maintenance iloilo, small business website philippines, professional website western visayas" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Mergewello Technologies" />
    <link rel="canonical" href={canonicalUrl} />

    {noindex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <meta
        name="robots"
        content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
      />
    )}

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}/og-image.jpg`} />
    <meta property="og:image:width" content="2400" />
    <meta property="og:image:height" content="1260" />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Mergewello Technologies" />
    <meta property="og:locale" content="en_PH" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/og-image.jpg`} />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@400;600;700&family=DM+Sans:wght@300;400;500;600;800&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@400;600;700&family=DM+Sans:wght@300;400;500;600;800&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />

    <meta name="generator" content={Astro.generator} />

    <StructuredData />
    <Analytics />
  </head>
  <body class="min-h-screen antialiased">
    <slot />

    <!-- Zoho SalesIQ -->
    <script is:inline>
      window.$zoho = window.$zoho || {};
      $zoho.salesiq = $zoho.salesiq || {
        ready: function () {
          console.log("Zoho SalesIQ loaded");
        }
      };
    </script>

    <script
      id="zsiqscript"
      src="https://salesiq.zohopublic.com/widget?wc=siq5f7e6429d462c53813ebb89ea8f08d01e8be1603dcd73e3c509d8f5d6e7e44805d32b82fe8f2d4d80174157f4be793fd"
      defer
    ></script>

    <style is:inline>
      #zsiq_float,
      .zsiq-float {
        right: 20px !important;
      }

      @media (max-width: 767px) {
        #zsiq_float,
        .zsiq-float {
          bottom: 90px !important;
          right: 12px !important;
        }
      }

      @media (min-width: 768px) {
        #zsiq_float,
        .zsiq-float {
          bottom: 20px !important;
          right: 30px !important;
        }
      }
    </style>
  </body>
</html>
