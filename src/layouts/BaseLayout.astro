---
import "../styles/global.css";
interface Props {
  title: string;
  description?: string;
  currentPage?: string;
}

const {
  title,
  description = "We help local businesses in Aklan, Antique, Capiz, and Iloilo get online.",
  currentPage = "",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | Mergewello Technologies`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://mergewello.com/og-image.jpg" />
    <meta property="og:url" content={`https://mergewello.com${Astro.url.pathname}`} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Mergewello Technologies" />

    <!-- Twitter/X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Mergewello Technologies`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://mergewello.com/og-image.png" />

    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">

    <link rel="apple-touch-icon" href="/apple-touch-icon.png">

    <link rel="manifest" href="/site.webmanifest">

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@400;600;700&family=DM+Sans:wght@300;400;500;600;800&display=swap" rel="stylesheet" />
    <title>{title} - Mergewello Technologies</title>
  </head>
  <body class="min-h-screen antialiased">
    <slot />
  </body>
</html>