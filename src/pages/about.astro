---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/sections/Navbar.astro";
import SocialSidebar from "../components/sections/SocialSidebar.astro";
import AboutIntro from "../components/sections/AboutIntro.astro";
import WhatMakesUsDifferent from "../components/sections/WhatMakesUsDifferent.astro";
import Footer from "../components/sections/Footer.astro";
import ScrollToTop from "../components/ui/ScrollToTop.astro";
---

<BaseLayout
  title="About Us — Web Developers in Western Visayas"
  description="Meet the team behind Mergewello Technologies. We're a web design agency based in Iloilo and Roxas City, serving local businesses across Aklan, Antique, Capiz, and Iloilo with fast, affordable websites."
>
  <Navbar currentPage="about" />
  <SocialSidebar />
  <AboutIntro />
  <WhatMakesUsDifferent />
  <Footer />
  <ScrollToTop />
  <div class="lg:hidden h-20"></div>
</BaseLayout>