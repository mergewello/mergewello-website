---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/sections/Navbar.astro";
import SocialSidebar from "../components/sections/SocialSidebar.astro";
import Hero from "../components/sections/Hero.astro";
import Pricing from "../components/sections/Pricing.astro";
import Contact from "../components/sections/Contact.astro";
import Footer from "../components/sections/Footer.astro";
import ScrollToTop from "../components/ui/ScrollToTop.astro";
---

<BaseLayout
  title="Affordable Web Design in Iloilo"
  description="Mergewello Technologies builds fast, modern websites for local businesses in Iloilo, Aklan, Antique, and Capiz. Professional web design starting at ₱3,000. Mobile-ready, SEO-optimized, delivered in 5 days."
>
  <Navbar currentPage="home" />
  <SocialSidebar />
  <Hero />
  <Pricing />
  <Contact />
  <Footer />
  <ScrollToTop />
  <div class="lg:hidden h-20"></div>
</BaseLayout>